async function noticias(){
try{

// 🔥 API NUEVA QUE FUNCIONA SIEMPRE
let res = await fetch("https://api.rss2json.com/v1/api.json?rss_url=https://news.google.com/rss?hl=es-419&gl=AR&ceid=AR:es");
let data = await res.json();

let html = "";

data.items.slice(0,6).forEach(noticia=>{
html += "🔴 " + noticia.title + "<br><br>";
});

document.getElementById("noticias").innerHTML = html;

}catch{
document.getElementById("noticias").innerHTML="⚠️ No se pudieron cargar las noticias";
}
}
